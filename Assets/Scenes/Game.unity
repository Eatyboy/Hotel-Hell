  m_Name: 
  m_EditorClassIdentifier: '::'
  floors:
  - sinName: LIMBO
    sinDescription: "\tAverage chaps. Didn\u2019t do anything wrong, but here they
      stay. "
    hellSprite: {fileID: 21300000, guid: 20547f2fd9ab77c438f3e19153a69929, type: 3}
  - sinName: LUST
    sinDescription: "Believes they\u2019re some sort of harem anime protagonist. "
    hellSprite: {fileID: 21300000, guid: dc9580654d17f95449b43444922d9abe, type: 3}
  - sinName: GLUTTONY
    sinDescription: 'Self-indulgent, lazy, wasteful beings. '
    hellSprite: {fileID: -5293263070474621911, guid: 4e0f842f211b2414f9f408dd313b76a4, type: 3}
  - sinName: GREED
    sinDescription: "Guard my belongings, Receptionist. These people really do steal
      anything\u2026 "
    hellSprite: {fileID: -5293263070474621911, guid: 4e0f842f211b2414f9f408dd313b76a4, type: 3}
  - sinName: ANGER
    sinDescription: 'Has only hate in their soul, but too scared to commit acts of
      violence. '
    hellSprite: {fileID: -5293263070474621911, guid: 4e0f842f211b2414f9f408dd313b76a4, type: 3}
  - sinName: HERESY
    sinDescription: "Dirty, dirty, liars. Don\u2019t let them fool you, Receptionist."
    hellSprite: {fileID: -5293263070474621911, guid: 4e0f842f211b2414f9f408dd313b76a4, type: 3}
  - sinName: VIOLENCE
    sinDescription: These chaps hurt others. Physically.
    hellSprite: {fileID: -5293263070474621911, guid: 4e0f842f211b2414f9f408dd313b76a4, type: 3}
  - sinName: FRAUD
    sinDescription: Lying on a larger scale compared to Heresy. Usually for profit.
    hellSprite: {fileID: -5293263070474621911, guid: 4e0f842f211b2414f9f408dd313b76a4, type: 3}
  - sinName: TREACHERY
    sinDescription: 'Traitors of the worst kind. Not an ounce of loyalty in their
      bones. '
    hellSprite: {fileID: -5293263070474621911, guid: 4e0f842f211b2414f9f408dd313b76a4, type: 3}
