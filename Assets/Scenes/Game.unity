  m_Name: 
  m_EditorClassIdentifier: '::'
  pause: {fileID: 1288972946}
  floors:
  - sinName: LIMBO
    sinDescription: "Average chaps. Didn\u2019t do anything wrong, but here they
      stay. "
    hellSprite: {fileID: 6947775041736957420, guid: a507cb73847e54adb94527760f910ca0, type: 3}
  - sinName: LUST
    sinDescription: "Believes they\u2019re some sort of harem anime protagonist. "
    hellSprite: {fileID: 6947775041736957420, guid: b7e801c2a41c143b8a440a268ddbda61, type: 3}
  - sinName: GLUTTONY
    sinDescription: 'Self-indulgent, lazy, wasteful beings. '
    hellSprite: {fileID: 6947775041736957420, guid: 79c7465ca006b4ae880bf9a67fb4cfb5, type: 3}
  - sinName: GREED
    sinDescription: "Guard my belongings, Receptionist. These people really do steal
      anything\u2026 "
    hellSprite: {fileID: 6947775041736957420, guid: 329a2405a2c3d47edb1f40b2f31768f5, type: 3}
  - sinName: ANGER
    sinDescription: 'Has only hate in their soul, but too scared to commit acts of
      violence. '
    hellSprite: {fileID: 6947775041736957420, guid: cf161ab8010b44e26a2d9e54424dd078, type: 3}
  - sinName: HERESY
    sinDescription: "Dirty, dirty, liars. Don\u2019t let them fool you, Receptionist."
    hellSprite: {fileID: 6947775041736957420, guid: 3f2695ab53131446c837115b0a6fa2ca, type: 3}
  - sinName: VIOLENCE
    sinDescription: "Physical damage, property damage, kidnapping\u2026Man, humans
      are evil. "
    hellSprite: {fileID: 6947775041736957420, guid: aed0f14130379433690f788c1909782e, type: 3}
  - sinName: FRAUD
    sinDescription: Lying on a larger scale compared to Heresy. Usually for profit.
    hellSprite: {fileID: 6947775041736957420, guid: b25b4a362393548f0a09c98f69316168, type: 3}
  - sinName: TREACHERY
    sinDescription: 'Traitors of the worst kind. Not an ounce of loyalty in their
      bones. '
    hellSprite: {fileID: 6947775041736957420, guid: b43591b86d3054cab8f2610de93f64ed, type: 3}
