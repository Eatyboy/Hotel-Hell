    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[0].sinnerDialogue
      value: "How ARR ya mate? Mighty \u2018ARRm in \u2018ere ain\u2019t it?"
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[1].sinnerDialogue
      value: "It CAHN\u2019T be that hard to sort me!"
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[2].sinnerDialogue
      value: "O-oh hello! Hell\u2019s scary, but I feel a lot braver because you\u2019re
        here >.<!"
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[3].sinnerDialogue
      value: HURRY WITH THE SORTING YOU F*CKING DONKEY!!!!!
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[4].sinnerDialogue
      value: "I had to wait 7 hours for this\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[5].sinnerDialogue
      value: Heed my words. I am John. Traitor of CDGV. And I have never known defeat
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[6].sinnerDialogue
      value: Free feet pics if you let me leave.
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[7].sinnerDialogue
      value: squeak squeak squee squeak (May I eat the flowers?)
      objectReference: {fileID: 0}
    - target: {fileID: 3725415731935696024, guid: 34e9e601759081049b685f4012c8e53f, type: 3}
      propertyPath: keySinnerList.Array.data[8].sinnerDialogue
      value: "I\u2019m a weirdo\u2026 I don\u2019t belong here!"
      objectReference: {fileID: 0}
